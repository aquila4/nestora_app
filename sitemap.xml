<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">

    <!-- HOME -->
    <url>
        <loc>https://www.usenestora.com/</loc>
        <changefreq>daily</changefreq>
        <priority>1.0</priority>
    </url>

    <!-- EXPLORE -->
    <url>
        <loc>https://www.usenestora.com/home</loc>
        <changefreq>daily</changefreq>
        <priority>0.9</priority>
    </url>

    <!-- LIST PROPERTY -->
    <url>
        <loc>https://www.usenestora.com/list-property/step1</loc>
        <changefreq>weekly</changefreq>
        <priority>0.8</priority>
    </url>

    <!-- 🏠 DYNAMIC PROPERTY PAGES -->
    {% for property in properties %}
    <url>
        <loc>https://www.usenestora.com/property/{{ property.id }}</loc>
        <changefreq>weekly</changefreq>
        <priority>0.9</priority>
    </url>
    {% endfor %}

    <!-- 👇 OPTIONAL: CITY SEO PAGES -->
    <url>
        <loc>https://www.usenestora.com/lagos-properties</loc>
        <changefreq>daily</changefreq>
        <priority>0.9</priority>
    </url>

    <url>
        <loc>https://www.usenestora.com/abuja-properties</loc>
        <changefreq>daily</changefreq>
        <priority>0.9</priority>
    </url>

</urlset>